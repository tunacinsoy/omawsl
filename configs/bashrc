# omawsl bashrc - baseline dev environment configuration for WSL2 Ubuntu.

case $- in
    *i*) ;;
      *) return;;
esac

HISTCONTROL=ignoreboth
HISTSIZE=10000
HISTFILESIZE=20000
shopt -s histappend
shopt -s checkwinsize

# Neovim is the only one of omawsl's 8 optional editor/AI-tool choices that's
# a general-purpose terminal text editor suited to $EDITOR/$VISUAL (VS
# Code/Cursor are GUI apps, the rest are AI coding agents, not blocking
# terminal editors) - so there's no real "which one is preferred" choice to
# make here, just whether nvim was installed at all. Falls back to nano
# (confirmed part of Ubuntu's base install, not something omawsl installs
# itself) so $EDITOR always points at something that exists, matching the
# same `command -v X &>/dev/null` guard already used below for every other
# optional tool in this file.
if command -v nvim &>/dev/null; then
  export EDITOR=nvim
  export VISUAL=nvim
else
  export EDITOR=nano
  export VISUAL=nano
fi

if [ -f ~/.inputrc ]; then
  export INPUTRC=~/.inputrc
fi

# Omakub-parity icon-only prompt: a single Nerd Font glyph in the prompt
# itself, path shown in the terminal tab/window title instead of inline.
# Falls back to a plain user@host:path prompt when OMAWSL_FONT_MODE (set at
# install time - docs/windows-setup.md#fonts) is the zero-install Cascadia
# Mono option: that glyph renders as a tofu box without a matching Nerd
# Font, confirmed on a real corporate machine without one installed.
# Missing/unset (e.g. an install that predates this choice) keeps today's
# icon-only default rather than silently changing existing prompts.
OMAWSL_FONT_MODE="$(grep -m1 '^OMAWSL_FONT_MODE=' "${OMAWSL_STATE_DIR:-$HOME/.local/state/omawsl}/choices.env" 2>/dev/null | cut -d'"' -f2)"
if [[ "$OMAWSL_FONT_MODE" == "Cascadia Mono"* ]]; then
  PS1='\u@\h:\w\$ '
else
  PS1=$' '
fi
PS1="\[\e]0;\w\a\]$PS1"
unset OMAWSL_FONT_MODE

if command -v eza &>/dev/null; then
  alias ls='eza -lh --group-directories-first --icons=auto'
  alias lsa='ls -a'
  alias ll='eza -la'
  alias lt='eza --tree --level=2 --long --icons --git'
  alias lta='lt -a'
  alias tree='eza --tree'
else
  alias ll='ls -la'
fi

# apt's `bat` package installs its binary as `batcat` (name collision with
# an unrelated pre-existing Debian package called `bat`) - checking for
# `bat` here would never be true on Ubuntu.
if command -v batcat &>/dev/null; then
  alias cat='batcat --paging=never'
fi

# Same Debian/Ubuntu package-name-collision situation as bat/batcat above:
# apt's `fd-find` package installs its binary as `fdfind`.
if command -v fdfind &>/dev/null; then
  alias fd='fdfind'
fi

if command -v fzf &>/dev/null && command -v batcat &>/dev/null; then
  alias ff="fzf --preview 'batcat --style=numbers --color=always {}'"
fi

if command -v zoxide &>/dev/null; then
  eval "$(zoxide init bash)"
  alias cd='z'
fi

alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

if command -v fzf &>/dev/null; then
  # shellcheck disable=SC1091
  source /usr/share/doc/fzf/examples/key-bindings.bash 2>/dev/null || true
  # fzf's own completion triggers (e.g. `**<Tab>`), separate from the
  # key-bindings file above - not present on every Ubuntu/fzf version, so
  # guarded the same defensive way.
  # shellcheck disable=SC1091
  source /usr/share/bash-completion/completions/fzf 2>/dev/null || true
fi

# System-wide tab completion (git, docker, apt, and many other commands) -
# apt-installed explicitly (see apps-terminal.sh), but sourcing it here is
# what actually activates it for interactive shells.
# shellcheck disable=SC1091
source /usr/share/bash-completion/bash_completion 2>/dev/null || true

if command -v git &>/dev/null; then
  alias g='git'
  alias gcm='git commit -m'
  alias gcam='git commit -a -m'
  alias gcad='git commit -a --amend'
fi

if command -v docker &>/dev/null; then
  alias d='docker'
fi

if command -v lazygit &>/dev/null; then
  alias lzg='lazygit'
fi

if command -v nvim &>/dev/null; then
  n() { if [ "$#" -eq 0 ]; then nvim .; else nvim "$@"; fi; }
fi

# Must come before the lazydocker/mise/rails checks below: those tools
# (like nvim above) aren't on PATH until this runs, so checking for them
# first would always fail and silently skip - confirmed as a real bug on
# an actual WSL2 run for mise (`mise --version` worked from a later shell
# only because this export ran unconditionally, but `mise activate` never
# fired, so `go`/`ruby`/`gem` were never actually reachable).
if [ -d "$HOME/.local/bin" ]; then
  export PATH="$HOME/.local/bin:$PATH"
fi

# lazydocker has no apt package - it installs to $HOME/.local/bin, only
# reachable after the PATH export above.
if command -v lazydocker &>/dev/null; then
  alias lzd='lazydocker'
fi

if command -v mise &>/dev/null; then
  eval "$(mise activate bash)"
fi

# rails isn't installed via apt - it's `gem install`'d under mise's
# managed Ruby, so its binary only becomes reachable once mise's shims are
# on PATH via the activation above, not any earlier.
if command -v rails &>/dev/null; then
  alias r='rails'
fi

# opencode's installer places its binary here, not $HOME/.local/bin like
# mise/lazydocker/claude - needs its own PATH entry.
if [ -d "$HOME/.opencode/bin" ]; then
  export PATH="$HOME/.opencode/bin:$PATH"
fi

# Omakub parity: every new interactive shell drops straight into zellij -
# upstream does this via Alacritty's own `[shell] program = "zellij"`
# config; omawsl has no Alacritty equivalent (Windows Terminal's WSL
# profile is dynamically generated per machine with its own GUID, too
# fragile to target directly), so the same effect is achieved here
# instead - terminal-emulator-agnostic, works the same in Windows
# Terminal, VS Code's integrated terminal, or over SSH. Must be the very
# last thing in this file: `exec` replaces the current shell process, so
# nothing after this line would ever run. Guarded on $ZELLIJ (which
# zellij itself sets in any shell it spawns) so opening a new pane/tab
# INSIDE an existing session doesn't try to exec another zellij - the
# same guard zellij's own docs recommend.
if [[ -z "${ZELLIJ:-}" ]] && command -v zellij &>/dev/null; then
  # WSL2/WSLg's $XDG_RUNTIME_DIR (/mnt/wslg/runtime-dir) is a synthetic
  # mount hardcoded to UID 1000 that doesn't reliably support the chmod
  # 0700 zellij needs on its own socket dir (microsoft/WSL#9689, #10896,
  # #11542) - zellij panics with a raw "Permission denied" instead of
  # degrading gracefully (zellij-org/zellij#4155). Point it at the same
  # /tmp-based directory zellij already falls back to when
  # XDG_RUNTIME_DIR is unset, sidestepping the broken mount entirely.
  export ZELLIJ_SOCKET_DIR="/tmp/zellij-$(id -u)"
  exec zellij
fi
